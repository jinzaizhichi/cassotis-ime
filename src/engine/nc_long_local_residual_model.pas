function signed_log1p(const value: Integer): Double;
begin
    if value < 0 then
    begin
        Result := -Ln(1.0 + Abs(value));
    end
    else
    begin
        Result := Ln(1.0 + value);
    end;
end;

function long_local_residual_score(const pool_rank: Integer;
    const char_lm_score: Integer; const seed_rank: Integer;
    const original: Boolean; const substitutions: Integer;
    const changed_position_ratio: Double; const source_char_weight: Integer;
    const replacement_char_weight: Integer): Double;
var
    features: array[0..c_feature_count - 1] of Double;
    hidden: array[0..c_hidden_units - 1] of Double;
    hidden_idx: Integer;
    feature_idx: Integer;
    value: Double;
begin
    features[0] := pool_rank;
    features[1] := char_lm_score;
    features[2] := seed_rank;
    if original then
    begin
        features[3] := 1.0;
    end
    else
    begin
        features[3] := 0.0;
    end;
    features[4] := substitutions;
    features[5] := changed_position_ratio;
    features[6] := Ln(1.0 + Max(0, source_char_weight));
    features[7] := Ln(1.0 + Max(0, replacement_char_weight));
    features[8] := signed_log1p(replacement_char_weight - source_char_weight);

    for hidden_idx := 0 to c_hidden_units - 1 do
    begin
        value := c_hidden_bias[hidden_idx];
        for feature_idx := 0 to c_feature_count - 1 do
        begin
            value := value + c_input_weights[
                hidden_idx * c_feature_count + feature_idx] *
                ((features[feature_idx] - c_feature_mean[feature_idx]) /
                c_feature_scale[feature_idx]);
        end;
        hidden[hidden_idx] := Tanh(value);
    end;

    Result := c_output_bias;
    for hidden_idx := 0 to c_hidden_units - 1 do
    begin
        Result := Result + c_output_weights[hidden_idx] * hidden[hidden_idx];
    end;
end;

